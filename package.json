{
  "name": "mcp",
  "version": "1.0.0",
  "description": "FPT AI Marketplace — Automation & Tooling",
  "main": "index.js",
  "scripts": {
    "postinstall": "cd automation-tests && pnpm install --frozen-lockfile || true",

    "test:marketplace":          "cd automation-tests && pnpm test:marketplace",
    "test:marketplace:smoke":    "cd automation-tests && pnpm --filter fpt-marketplace test:smoke",
    "test:marketplace:regression": "cd automation-tests && pnpm --filter fpt-marketplace test:regression",
    "test:marketplace:api":      "cd automation-tests && pnpm --filter fpt-marketplace test:api",
    "test:marketplace:api:vn":   "cd automation-tests && pnpm --filter fpt-marketplace test:api:vn",
    "test:marketplace:api:jp":   "cd automation-tests && pnpm --filter fpt-marketplace test:api:jp",
    "test:marketplace:api:vn:prod": "cd automation-tests && cross-env APP_ENV=prod pnpm --filter fpt-marketplace test:api:vn",
    "test:marketplace:api:jp:prod": "cd automation-tests && cross-env APP_ENV=prod pnpm --filter fpt-marketplace test:api:jp",
    "test:ai":                   "cd automation-tests && pnpm test:ai",
    "test:portal":               "cd automation-tests && pnpm test:portal",
    "test:billing":              "cd automation-tests && pnpm test:billing",
    "test:all":                  "cd automation-tests && pnpm test:all",
    "test:report":               "cd automation-tests && pnpm --filter fpt-marketplace report",

    "agent":              "npx ts-node agents/orchestrator.ts --agent",
    "agent:test":         "npx ts-node agents/test-agent.ts",
    "agent:test:login":   "npx ts-node agents/test-agent.ts --flow login",
    "agent:test:search":  "npx ts-node agents/test-agent.ts --flow search",
    "agent:test:checkout":"npx ts-node agents/test-agent.ts --flow checkout",
    "agent:codegen":      "npx ts-node agents/codegen-agent.ts",
    "agent:jira":         "npx ts-node agents/jira-agent.ts",

    "checkly:login":  "checkly login",
    "checkly:test":   "checkly test --config checkly.config.js --verbose",
    "checkly:deploy": "checkly deploy",

    "slack:report":      "npx ts-node utils/slack-report.ts",
    "slack:report:stg":  "cross-env APP_ENV=stg npx ts-node utils/slack-report.ts",
    "slack:report:prod": "cross-env APP_ENV=prod npx ts-node utils/slack-report.ts",

    "jira:report":    "npx ts-node utils/jira-reporter.ts",
    "jira:dry-run":   "npx ts-node utils/jira-reporter.ts --dry-run",
    "jira:testcase":  "npx ts-node utils/jira-to-testcase.ts",

    "dashboard":      "node utils/report-server.js",
    "dashboard:skill": "node utils/dashboard-server.js",
    "dashboard:refresh": "node utils/generate-dashboard-data.js",
    "webhook":        "npx ts-node utils/webhook-server.ts",
    "openclaw":       "npx ts-node utils/openclaw-agent.ts",
    "usage":          "npx ts-node utils/usage-dashboard.ts",
    "usage:key":      "npx ts-node utils/usage-dashboard.ts --key v1",

    "agent":          "npx ts-node utils/claude-glm-agent.ts",
    "glm:generate":   "npx ts-node utils/glm-direct.ts --api-models",
    "glm:analyze":    "npx ts-node utils/glm-analyze-results.ts",
    "vlm:analyze":    "npx ts-node utils/vlm-ui-analyzer.ts",
    "vlm:mockup":     "npx ts-node utils/vlm-mockup-analyze.ts",
    "browser:inspect":"npx ts-node utils/browser-inspect-gen.ts",
    "translate":      "npx ts-node utils/translate.ts",
    "translate:vi":   "npx ts-node utils/translate.ts --to vi",
    "translate:en":   "npx ts-node utils/translate.ts --to en",

    "checkly:gen-vn": "node utils/generate-checkly-checks.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "checkly": "^7.7.0",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1",
    "https-proxy-agent": "^8.0.0",
    "langfuse": "^3.38.6",
    "openai": "^6.29.0",
    "undici": "^7.24.2"
  },
  "directories": {
    "test": "automation-tests"
  }
}

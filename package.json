    "test:env:stg:regression": "cross-env APP_ENV=stg playwright test --project=regression",
    "test:env:prod:regression": "cross-env APP_ENV=prod playwright test --project=regression",
    "report:test": "playwright show-report reports/test/playwright-report --port 9323",

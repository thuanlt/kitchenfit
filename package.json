    "test:prod:dashboard": "cross-env APP_ENV=prod playwright test && node utils/report-server.js",
    "test:env:test": "cross-env APP_ENV=test playwright test",
    "test:env:stg": "cross-env APP_ENV=stg playwright test",
    "test:env:prod": "cross-env APP_ENV=prod playwright test",
